{
  "entities": {
    "Stat": {
      "title": "Statistics",
      "description": "Visitor statistics for posts",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "views": { "type": "integer" },
        "clicks": { "type": "integer" },
        "impressions": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "updatedAt"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "Global settings for the admin panel",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "IndexingStatus": {
      "title": "Indexing Status",
      "description": "Search engine indexing status for posts",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "google_status": { "type": "string" },
        "naver_status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "updatedAt"]
    },
    "Post": {
      "title": "Post Content",
      "description": "Article/Post data including markdown content",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "hub": { "type": "string" },
        "flowStep": { "type": "integer" },
        "status": { "type": "string" },
        "publishAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "content", "status"]
    },
    "SecurityConfig": {
      "title": "Security Configuration",
      "description": "Administrative security settings",
      "type": "object",
      "properties": {
        "adminPassword": { "type": "string" }
      },
      "required": ["adminPassword"]
    }
  },
  "firestore": {
    "indexes": [
      {
        "collectionGroup": "posts",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "status", "order": "ASCENDING" },
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ]
      },
      {
        "collectionGroup": "posts",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ]
      }
    ],
    "/posts/{slug}": {
      "schema": "Post",
      "description": "Full post content and metadata"
    },
    "/settings/security": {
      "schema": "SecurityConfig",
      "description": "Critical security parameters including admin password"
    },
    "/stats/{slug}": {
      "schema": "Stat",
      "description": "Post visit and interaction stats"
    },
    "/admin_config/{key}": {
      "schema": "AdminConfig",
      "description": "Admin settings and hashed secrets"
    },
    "/settings/security": {
      "schema": "object",
      "description": "Critical security parameters including admin password"
    },
    "/indexing_status/{slug}": {
      "schema": "IndexingStatus",
      "description": "SEO indexing status tracking"
    }
  }
}
